<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ShellDroid" parent="Theme.Material3.DayNight.NoActionBar" />

    <!--
        Splash screen theme used only for the launch window. On Android 12+
        this drives the SplashScreen API (background + icon window + swap);
        on older versions it falls back to a plain window background that
        matches the app's dark background so the user doesn't see a white
        flash. Applied to the MainActivity in the manifest; the activity
        itself calls installSplashScreen() in onCreate which transitions
        the window to Theme.ShellDroid once Compose is ready.
    -->
    <style name="Theme.ShellDroid.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/colorBackground</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/colorBackground</item>
        <item name="postSplashScreenTheme">@style/Theme.ShellDroid</item>
    </style>
</resources>
